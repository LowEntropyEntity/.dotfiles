[alias]
	grep-all = ! echo "error: in dotfiles" >&2; exit 1

[core]
	excludesFile = .config/git/dotfiles/ignore
	hooksPath = .config/git/dotfiles/hooks

[oh-my-zsh]
	hide-info = 1

[submodule ".config/alacritty/catppuccin"]
	active = true
	url = https://github.com/catppuccin/alacritty.git

[submodule ".config/eza/eza-themes"]
	active = true
	url = https://github.com/eza-community/eza-themes.git

[submodule ".config/waybar/catppuccin"]
	active = true
	url = https://github.com/catppuccin/waybar.git

[submodule ".config/wofi/catppuccin"]
	active = true
	url = https://github.com/quantumfate/wofi.git

[submodule ".oh-my-zsh"]
	active = true
	url = https://github.com/ohmyzsh/ohmyzsh.git

[submodule ".oh-my-zsh-custom/plugins/fzf-tab"]
	active = true
	url = https://github.com/Aloxaf/fzf-tab

[submodule ".src/aur.archlinux.org/yay"]
	active = true
	url = https://aur.archlinux.org/yay.git

[submodule ".tmux/plugins/tpm"]
	active = true
	url = https://github.com/tmux-plugins/tpm.git
